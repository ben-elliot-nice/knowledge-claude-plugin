# CXone Expert credentials
# Copy this file to .env in your project root and fill in values.
# Add .env to .gitignore — never commit credentials.

# Base URL of your Expert instance (no trailing slash)
EXPERT_BASE_URL=https://your-instance.mindtouch.us

# Developer token key and secret (from Expert Admin > API Keys)
EXPERT_KEY=your_key_here
EXPERT_SECRET=your_secret_here

# Default parent path for categories when no parent is specified
# e.g. "home" for root, or a specific page path like "MUFG"
EXPERT_ROOT_PATH=home
